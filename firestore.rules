rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny Everything (Zero Trust Policy)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidEmailId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^.+@.+$');
    }

    // Secure field locks: evaluates if the field is omitted or matches existing state
    function fieldHasNotChanged(fieldName) {
      return !(fieldName in request.resource.data) || 
             (fieldName in resource.data && request.resource.data[fieldName] == resource.data[fieldName]);
    }

    // Fetch the user's document database record securely
    function getUserRecord(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function hasUserRecord(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function isGlobalAdmin() {
      return isSignedIn() &&
             hasUserRecord(request.auth.uid) &&
             getUserRecord(request.auth.uid).get('isAdmin', false) == true;
    }

    function isCompanyOwner(companyId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/companies/$(companyId)) &&
             get(/databases/$(database)/documents/companies/$(companyId)).data.get('ownerId', '') == request.auth.uid;
    }

    function isCompanyAdmin(companyId) {
      return isSignedIn() && (
        isGlobalAdmin() ||
        isCompanyOwner(companyId) ||
        (hasUserRecord(request.auth.uid) && 
         getUserRecord(request.auth.uid).get('companyId', '') == companyId && 
         getUserRecord(request.auth.uid).get('isAdmin', false) == true)
      );
    }

    // User Profile Rules with Strict Privilege Guardrails
    match /users/{userId} {
      // Users can only read their own profile, unless they are a global admin or in the same company
      allow get: if isOwner(userId) || isGlobalAdmin() || (
        isSignedIn() &&
        hasUserRecord(request.auth.uid) &&
        getUserRecord(request.auth.uid).get('companyId', '') != '' &&
        getUserRecord(request.auth.uid).get('companyId', '') == resource.data.get('companyId', '')
      );
      
      // Allow listing users matching company boundaries (Query Enforcer)
      allow list: if isSignedIn() && (
        isGlobalAdmin() || 
        (hasUserRecord(request.auth.uid) && resource.data.companyId == getUserRecord(request.auth.uid).get('companyId', ''))
      );

      // Creation: Only the user can create their own profile. Pre-allocate safe default privileges.
      allow create: if isOwner(userId) && isValidId(userId) &&
                     request.resource.data.get('isAdmin', false) == false &&
                     request.resource.data.get('role', 'user') == 'user';

      // Update: User can update profile, but CANNOT self-elevate roles, permissions, or admin state
      allow update: if isGlobalAdmin() || (
        isOwner(userId) &&
        fieldHasNotChanged('isAdmin') &&
        fieldHasNotChanged('role') &&
        fieldHasNotChanged('permissions')
      );

      // Deletion: Strictly administrators only
      allow delete: if isGlobalAdmin();
    }

    // Companies Rules
    match /companies/{companyId} {
      // Get/List: Any signed-in user can retrieve or list companies (necessary for onboarding and group lists)
      allow read: if isSignedIn();

      // Create: Only administrators can register/create a company
      allow create: if isGlobalAdmin() && isValidId(companyId);

      // Update/Delete: Only company owners or company/global admins can update or delete
      allow update, delete: if isSignedIn() && (
        isGlobalAdmin() ||
        isCompanyOwner(companyId)
      );

      // Company Whitelists Subcollection
      match /whitelist/{emailId} {
        // Individual email lookup for registration matching
        allow get: if isSignedIn() && isValidEmailId(emailId) && (
          emailId == request.auth.token.email ||
          isCompanyAdmin(companyId)
        );
        // Broad listing of whitelist emails
        allow list: if isCompanyAdmin(companyId);
        // Adding or removing emails from the whitelist
        allow write: if isCompanyAdmin(companyId) && isValidEmailId(emailId);
      }
    }
  }
}
