rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny Everything
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Fetch the user's document database record securely
    function getUserRecord(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function hasUserRecord(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function isGlobalAdmin() {
      return isSignedIn() &&
             hasUserRecord(request.auth.uid) &&
             getUserRecord(request.auth.uid).get('isAdmin', false) == true;
    }

    // User Profile Rules
    match /users/{userId} {
      // Users can only read their own profile, unless they are a global admin
      allow get: if isOwner(userId) || isGlobalAdmin();
      
      // Allow listing users matching company boundaries (Query Enforcer)
      allow list: if isSignedIn() && (
        isGlobalAdmin() || 
        (resource.data.companyId == getUserRecord(request.auth.uid).get('companyId', ''))
      );

      // Creation: Only the user can create their own profile. SettingisAdmin must be forbidden unless done by a global admin
      allow create: if isOwner(userId) && isValidId(userId) && (
        !incoming().get('isAdmin', false) || isGlobalAdmin()
      );

      // Update: User can update their own data, but cannot change administrative or structural fields like isAdmin, or companyId.
      allow update: if isGlobalAdmin() || (
        isOwner(userId) && 
        incoming().get('isAdmin', false) == existing().get('isAdmin', false) &&
        incoming().get('companyId', '') == existing().get('companyId', '')
      );

      // Deletion: Strictly administrators only
      allow delete: if isGlobalAdmin();
    }

    // Companies Rules
    match /companies/{companyId} {
      // Get: Members of the company or admins can get the document
      allow get: if isSignedIn() && isValidId(companyId) && (
        isGlobalAdmin() ||
        (hasUserRecord(request.auth.uid) && getUserRecord(request.auth.uid).get('companyId', '') == companyId)
      );

      // List: Only administrators are permitted to list all companies
      allow list: if isSignedIn() && isGlobalAdmin();

      // Mutation: Administrators only can create/update/delete companies
      allow create: if isGlobalAdmin() && isValidId(companyId) && incoming().name is string;
      allow update: if isGlobalAdmin() && isValidId(companyId);
      allow delete: if isGlobalAdmin() && isValidId(companyId);

      // Company Whitelists Subcollection
      match /whitelist/{emailId} {
        allow read: if isSignedIn() && isValidId(emailId) && (
          isGlobalAdmin() ||
          (hasUserRecord(request.auth.uid) && getUserRecord(request.auth.uid).get('companyId', '') == companyId)
        );
        allow write: if isGlobalAdmin() && isValidId(emailId);
      }
    }
  }
}
